generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model cart_items {
  id         Int       @id @default(autoincrement())
  cart_id    Int
  product_id Int
  variant_id Int?
  quantity   Int       @default(1)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  updated_at DateTime? @default(now()) @db.Timestamp(0)
  carts      carts     @relation(fields: [cart_id], references: [id], onDelete: Cascade, map: "fk_cart_items_carts")
  products   products  @relation(fields: [product_id], references: [id], map: "fk_cart_items_products")
  variants   variants? @relation(fields: [variant_id], references: [id], map: "fk_cart_items_variants")

  @@index([cart_id], map: "fk_cart_items_carts")
  @@index([product_id], map: "fk_cart_items_products")
  @@index([variant_id], map: "fk_cart_items_variants")
}

model carts {
  id         Int           @id @default(autoincrement())
  user_id    Int           @unique(map: "user_id")
  status     carts_status? @default(ACTIVE)
  created_at DateTime?     @default(now()) @db.Timestamp(0)
  updated_at DateTime?     @default(now()) @db.Timestamp(0)
  cart_items cart_items[]
  users      users         @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_carts_users")
}

model categories {
  id         Int        @id @default(autoincrement())
  name       String     @unique(map: "name") @db.VarChar(100)
  created_at DateTime?  @default(now()) @db.Timestamp(0)
  updated_at DateTime?  @default(now()) @db.Timestamp(0)
  products   products[]
}

model order_items {
  id           Int       @id @default(autoincrement())
  order_id     Int
  product_id   Int
  variant_id   Int?
  product_name String    @db.VarChar(150)
  size         String?   @db.VarChar(10)
  color        String?   @db.VarChar(50)
  quantity     Int
  unit_price   Decimal   @db.Decimal(10, 2)
  total_price  Decimal   @db.Decimal(10, 2)
  created_at   DateTime? @default(now()) @db.Timestamp(0)
  orders       orders    @relation(fields: [order_id], references: [id], onDelete: Cascade, map: "fk_order_items_orders")
  products     products  @relation(fields: [product_id], references: [id], map: "fk_order_items_products")
  variants     variants? @relation(fields: [variant_id], references: [id], map: "fk_order_items_variants")

  @@index([order_id], map: "fk_order_items_orders")
  @@index([product_id], map: "fk_order_items_products")
  @@index([variant_id], map: "fk_order_items_variants")
}

model orders {
  id               Int            @id @default(autoincrement())
  user_id          Int
  status           orders_status? @default(PENDING)
  total_amount     Decimal        @default(0.00) @db.Decimal(10, 2)
  payment_method   String?        @db.VarChar(50)
  shipping_address String?        @db.Text
  created_at       DateTime?      @default(now()) @db.Timestamp(0)
  updated_at       DateTime?      @default(now()) @db.Timestamp(0)
  order_items      order_items[]
  users            users          @relation(fields: [user_id], references: [id], map: "fk_orders_users")
  sales            sales[]

  @@index([user_id], map: "fk_orders_users")
}

model products {
  id             Int           @id @default(autoincrement())
  name           String        @db.VarChar(150)
  description    String?       @db.Text
  price          Decimal       @db.Decimal(10, 2)
  stock_quantity Int           @default(0)
  category_id    Int
  created_at     DateTime?     @default(now()) @db.Timestamp(0)
  updated_at     DateTime?     @default(now()) @db.Timestamp(0)
  cart_items     cart_items[]
  order_items    order_items[]
  categories     categories    @relation(fields: [category_id], references: [id], map: "fk_products_categories")
  reviews        reviews[]
  sales          sales[]
  variants       variants[]

  @@index([category_id], map: "fk_products_categories")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reviews {
  id         Int       @id @default(autoincrement())
  user_id    Int
  product_id Int
  rating     Int
  comment    String?   @db.Text
  created_at DateTime? @default(now()) @db.Timestamp(0)
  updated_at DateTime? @default(now()) @db.Timestamp(0)
  products   products  @relation(fields: [product_id], references: [id], onDelete: Cascade, map: "fk_reviews_products")
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_reviews_users")

  @@unique([user_id, product_id], map: "uq_reviews_user_product")
  @@index([product_id], map: "fk_reviews_products")
}

model sales {
  id               Int       @id @default(autoincrement())
  order_id         Int
  product_id       Int
  variant_id       Int?
  product_name     String    @db.VarChar(150)
  product_category String?   @db.VarChar(100)
  size             String?   @db.VarChar(10)
  color            String?   @db.VarChar(50)
  quantity         Int
  unit_price       Decimal   @db.Decimal(10, 2)
  total_price      Decimal   @db.Decimal(10, 2)
  customer_id      Int
  sold_at          DateTime? @default(now()) @db.Timestamp(0)
  orders           orders    @relation(fields: [order_id], references: [id], map: "fk_sales_orders")
  products         products  @relation(fields: [product_id], references: [id], map: "fk_sales_products")
  users            users     @relation(fields: [customer_id], references: [id], map: "fk_sales_users")
  variants         variants? @relation(fields: [variant_id], references: [id], map: "fk_sales_variants")

  @@index([order_id], map: "fk_sales_orders")
  @@index([product_id], map: "fk_sales_products")
  @@index([customer_id], map: "fk_sales_users")
  @@index([variant_id], map: "fk_sales_variants")
}

model users {
  id         Int           @id @default(autoincrement())
  name       String        @db.VarChar(150)
  birth_date DateTime      @db.Date
  email      String        @unique(map: "email") @db.VarChar(150)
  cpf        String        @unique(map: "cpf") @db.VarChar(14)
  phone      String?       @db.VarChar(20)
  gender     users_gender?
  password   String        @db.VarChar(255)
  role       users_role?   @default(CUSTOMER)
  created_at DateTime?     @default(now()) @db.Timestamp(0)
  updated_at DateTime?     @default(now()) @db.Timestamp(0)
  carts      carts?
  orders     orders[]
  reviews    reviews[]
  sales      sales[]
}

model variants {
  id             Int           @id @default(autoincrement())
  product_id     Int
  size           String?       @db.VarChar(10)
  color          String?       @db.VarChar(50)
  stock_quantity Int           @default(0)
  created_at     DateTime?     @default(now()) @db.Timestamp(0)
  updated_at     DateTime?     @default(now()) @db.Timestamp(0)
  cart_items     cart_items[]
  order_items    order_items[]
  sales          sales[]
  products       products      @relation(fields: [product_id], references: [id], onDelete: Cascade, map: "fk_variants_products")

  @@index([product_id], map: "fk_variants_products")
}

enum carts_status {
  ACTIVE
  ABANDONED
  CONVERTED
}

enum orders_status {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum users_gender {
  M
  F
  O
}

enum users_role {
  ADMIN
  CUSTOMER
}
